{{>layout/header}}
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<style>
    :root { --primary-color: #2563eb; }
    body { font-family: 'Pretendard', sans-serif; line-height: 1.6; color: #334155; }
    .hero-section { padding: 100px 0; background: #f8fafc; }
    .section-title { font-weight: 800; margin-bottom: 2rem; color: #1e293b; }
    .skill-badge { background: #eff6ff; color: var(--primary-color); padding: 0.5rem 1rem; border-radius: 8px; font-weight: 600; margin: 0.2rem; display: inline-block; }
    .card { border: none; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); transition: 0.3s; }
    .card:hover { transform: translateY(-5px); }
    .timeline-item { border-left: 2px solid #e2e8f0; padding-left: 20px; margin-bottom: 20px; position: relative; }
    .timeline-item::before { content: ''; position: absolute; left: -6px; top: 0; width: 12px; height: 12px; background: var(--primary-color); border-radius: 50%; }
</style>

<div class="container py-5">
    <!-- 1. Hero Section -->
    <section class="hero-section text-center rounded-3">
        <h1 class="display-3 fw-bold">천현종</h1>
        <p class="lead text-primary fw-bold">Backend Developer | 환경데이터 연구원 출신</p>
        <p class="mt-3">사용자 경험을 우선하는 개발자가 되겠습니다.</p>
        <div class="mt-4">
            <a href="https://github.com/Hj-1000/practice1" class="btn btn-dark px-4 mx-1">GitHub</a>
<!--            <a href="#" class="btn btn-outline-primary px-4 mx-1">Blog</a>-->
<!--            <a href="#" class="btn btn-primary px-4 mx-1">이력서 다운로드</a>-->
            <div class="mt-4">
                {{#userName}}
                    <div class="d-flex justify-content-center align-items-center">
                        <span class="badge bg-light text-dark p-2 me-3 border">Logged in: {{userName}}</span>
                        <a href="/logout" class="btn btn-sm btn-outline-danger">로그아웃</a>
                    </div>
                {{/userName}}
                {{^userName}}
                    <!-- 모달을 호출하는 버튼 -->
                    <button type="button" class="btn btn-primary btn-lg px-4" data-bs-toggle="modal" data-bs-target="#loginModal">
                        프로젝트 체험하기
                    </button>
                {{/userName}}
            </div>
        </div>
    </section>

    <!-- 2. About Me -->
    <section class="my-5">
        <h2 class="section-title">About Me</h2>
        <p>환경 연구 데이터 분석 경험을 바탕으로, 데이터의 무결성을 중요하게 생각합니다. 단순히 코드를 짜는 것을 넘어, 안정적인 서비스 운영과 CI/CD 파이프라인 구축을 즐기는 백엔드 개발자입니다.</p>
    </section>

    <!-- 6. Tech Stack -->
    <section class="my-5">
        <h2 class="section-title">Tech Stack</h2>
        <div class="mb-3"><h5>Backend</h5> <div id="backend-skills">
            <span class="skill-badge">Java</span> <span class="skill-badge">Spring Boot</span> <span class="skill-badge">JPA</span> <span class="skill-badge">QueryDSL</span>
        </div></div>
        <div class="mb-3"><h5>Infra</h5> <div id="infra-skills">
            <span class="skill-badge">AWS EC2</span> <span class="skill-badge">Docker</span> <span class="skill-badge">GitHub Actions</span> <span class="skill-badge">Nginx</span>
        </div></div>
    </section>

    <!-- 8. Architecture (Diagram Card) -->
    <section class="my-5">
        <h2 class="section-title">Architecture</h2>
        <div class="card p-4 bg-dark text-white">
            <div class="d-flex justify-content-around align-items-center">
                <span>Client</span> <i class="fas fa-arrow-right"></i>
                <span>Nginx (Proxy)</span> <i class="fas fa-arrow-right"></i>
                <span>Spring Boot (AWS EC2)</span> <i class="fas fa-arrow-right"></i>
                <span>MariaDB</span>
            </div>
            <p class="text-center mt-3 text-info small">GitHub Actions를 통한 무중단 배포 자동화 파이프라인 구축 완료</p>
        </div>
    </section>

    <!-- 7. Projects -->
    <section class="my-5">
        <h2 class="section-title">Portfolio Projects</h2>
        <div class="row row-cols-1 row-cols-md-3 g-4">

            <div class="col">
                <div class="card h-100 portfolio-card shadow-sm"
                     onclick="checkLoginAndRedirect('/reviews', {{#userName}}true{{/userName}}{{^userName}}false{{/userName}})"
                     style="cursor:pointer;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center text-primary mb-3">
                            <i class="fas fa-map-marked-alt fa-2x"></i>
                            <span class="badge rounded-pill" style="background-color: #eff6ff; color: #2563eb; font-weight: 600;">개인프로젝트</span>
                        </div>
                        <h5>맛집 기록 서비스</h5>
                        <ul class="small mt-3 text-muted"> <li><strong>Tech:</strong> Spring Boot, JPA, 카카오맵 API</li>
                            <li><strong>Point:</strong> JPA 지연 로딩 최적화, 좌표 기반 1km 거리 계산</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 portfolio-card shadow-sm"
                     onclick="checkLoginAndRedirect('https://www.gangnamon.or.kr/', {{#userName}}true{{/userName}}{{^userName}}false{{/userName}})"
                     style="cursor:pointer;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center text-primary mb-3">
                            <i class="fas fa-hospital fa-2x"></i>
                            <span class="badge rounded-pill" style="background-color: #fefce8; color: #a16207; font-weight: 600;">와일리</span>
                        </div>
                        <h5>강남구중독관리 통합지원센터</h5>
                        <ul class="small mt-3 text-muted"> <li><strong>Tech:</strong> NEXT.js, AI agent</li>
                            <li><strong>Point:</strong> 신규 홈페이지 구축</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col">
                <div class="card h-100 portfolio-card shadow-sm"
                     onclick="checkLoginAndRedirect('https://github.com/Hj-1000/HotelProj/', {{#userName}}true{{/userName}}{{^userName}}false{{/userName}})"
                     style="cursor:pointer;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center text-primary mb-3">
                            <i class="fas fa-hotel fa-2x"></i>
                            <span class="badge rounded-pill" style="background-color: #ecfdf5; color: #059669; font-weight: 600;">팀프로젝트</span>
                        </div>
                        <h5>호텔예약프로그램</h5>
                        <ul class="small mt-3 text-muted"> <li><strong>Tech:</strong> Spring Boot, JPA, Open AI</li>
                            <li><strong>Point:</strong> 예약, 주문, 접속권한분리</li>
                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- 3 & 4. Career & Education -->
    <div class="row">
        <section class="col-md-6">
            <h2 class="section-title">Career</h2>
            <div class="timeline-item">
                <h6 class="fw-bold">와일리 (Wiley)</h6>
                <p class="small">Next.js 홈페이지 구축, 유지보수 및 배포 이슈 대응</p>
            </div>
            <div class="timeline-item">
                <h6 class="fw-bold">(주)네오엔비즈</h6>
                <p class="small">환경데이터 분석 및 실험, 보고서 작성</p>
            </div>
        </section>
        <section class="col-md-6">
            <h2 class="section-title">Education</h2>
            <div class="timeline-item">
                <p><strong>국민대학교 산림환경시스템학 전공</strong><br>GIS 데이터 분석 및 공간정보 처리 경험</p>
            </div>
            <div class="timeline-item">
                <p><strong>우리인재개발원</strong><br>AWS기반 HyperAutomation융합 웹서비스플랫폼개발(JAVA,Python,RPA)</p>
            </div>
        </section>
    </div>
</div>

<div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="loginModalLabel">로그인</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <p class="text-muted mb-4">서비스 상세 기능을 위해 로그인이 필요합니다.</p>
                <div class="d-grid gap-3 px-4">
                    <a href="/oauth2/authorization/google" class="btn btn-outline-dark btn-lg">
                        <i class="fab fa-google me-2"></i> Google
                    </a>
                    <a href="/oauth2/authorization/naver" class="btn btn-outline-success btn-lg">
                        <i class="fas fa-n me-2"></i> Naver
                    </a>
                    <hr class="my-2">
                    <form action="/login/demo" method="post">
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="fas fa-user-secret me-2"></i> 데모 계정으로 체험하기
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function checkLoginAndRedirect(url, isLoggedIn) {
        if (isLoggedIn) {
            // 로그인 상태면 해당 페이지로 이동
            location.href = url;
        } else {
            // 로그인 안 됐으면 모달창 띄우기
            var loginModal = new bootstrap.Modal(document.getElementById('loginModal'));
            loginModal.show();
        }
    }
</script>
{{>layout/footer}}