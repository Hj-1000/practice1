{{>layout/header}}

<div class="container mt-4" style="max-width: 700px;">
    <h2 class="font-weight-bold mb-3">🍽️ 맛집 기억 수정 / 삭제</h2>
    <hr>

    <form>
        <input type="text" id="reviewId" value="{{review.id}}" hidden readonly>
        <input type="number" id="originRating" value="{{review.ratingStars.length}}" hidden readonly>

        <div class="mb-3">
            <label for="placeName" class="form-label font-weight-bold">가게 이름</label>
            <input type="text" class="form-control bg-light" id="placeName" value="{{review.placeName}}" readonly>
        </div>

        <div class="mb-3">
            <label for="category" class="form-label font-weight-bold">카테고리</label>
            <input type="text" class="form-control bg-light" id="category" value="{{review.category}}" readonly>
        </div>

        <div class="mb-3">
            <label for="addressName" class="form-label font-weight-bold">주소</label>
            <input type="text" class="form-control bg-light" id="addressName" value="{{review.addressName}}" readonly>
        </div>

        <div class="mb-3">
            <label for="visitDate" class="form-label font-weight-bold">방문 날짜</label>
            <input type="text" class="form-control bg-light" id="visitDate" value="{{review.visitDate}}" readonly>
        </div>

        <hr>

        <div class="mb-3">
            <label for="rating" class="form-label font-weight-bold text-primary">⭐ 평점 변경</label>
            <select class="form-select" id="rating">
                <option value="5">⭐⭐⭐⭐⭐ (최고)</option>
                <option value="4">⭐⭐⭐⭐ (만족)</option>
                <option value="3">⭐⭐⭐ (보통)</option>
                <option value="2">⭐⭐ (그저 그럼)</option>
                <option value="1">⭐ (별로)</option>
            </select>
        </div>

        {{#review.imageUrl}}
            <div class="mb-3">
                <label class="form-label font-weight-bold d-block">📸 등록된 사진</label>
                <img src="{{review.imageUrl}}" class="img-thumbnail" style="max-width: 100%; max-height: 300px;" alt="리뷰 사진">
            </div>
        {{/review.imageUrl}}

        <div class="mb-4">
            <label for="review-content" class="form-label font-weight-bold text-primary">식당 후기 수정</label>
            <textarea class="form-control" id="review-content" rows="5">{{review.content}}</textarea>
        </div>

        <div class="d-flex justify-content-between gap-2">
            <a href="/reviews" class="btn btn-secondary py-2" style="width: 30%;">취소</a>
            <button type="button" class="btn btn-danger py-2" id="btn-delete-review" style="width: 30%;">삭제하기</button>
            <button type="button" class="btn btn-success py-2" id="btn-update-review" style="width: 35%;">수정 완료</button>
        </div>
    </form>
</div>

{{>layout/footer}}