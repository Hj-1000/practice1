{{>layout/header}}

<div class="container mt-5" style="max-width: 760px;">
    <div class="bg-white p-5 rounded-4 border shadow-sm" style="border-color: #eaeef2 !important;">
        <div class="mb-4">
            <h3 class="fw-bold" style="color: var(--feed-text-dark);">🍽️ 미식 기억 수정 / 삭제</h3>
            <p class="text-muted small">기록된 추억을 편집하거나 정리할 수 있습니다.</p>
        </div>
        <hr class="mb-4">

        <form>
            <input type="text" id="reviewId" value="{{review.id}}" hidden readonly>
            <input type="number" id="originRating" value="{{review.ratingStars.length}}" hidden readonly>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="placeName" class="form-label fw-bold small text-muted">가게 명칭</label>
                    <input type="text" class="form-control bg-light border-0 py-2 rounded-3" id="placeName" value="{{review.placeName}}" readonly>
                </div>
                <div class="col-md-6 mb-3">
                    <label for="category" class="form-label fw-bold small text-muted">카테고리</label>
                    <input type="text" class="form-control bg-light border-0 py-2 rounded-3" id="category" value="{{review.category}}" readonly>
                </div>
            </div>

            <div class="mb-3">
                <label for="addressName" class="form-label fw-bold small text-muted">식당 위치</label>
                <input type="text" class="form-control bg-light border-0 py-2 rounded-3" id="addressName" value="{{review.addressName}}" readonly>
            </div>

            <div class="mb-3">
                <label for="visitDate" class="form-label fw-bold small text-muted">최초 방문 시간</label>
                <input type="text" class="form-control bg-light border-0 py-2 rounded-3" id="visitDate" value="{{review.visitDate}}" readonly>
            </div>

            <hr class="my-4" style="border-style: dashed;">

            <div class="mb-4">
                <label for="rating" class="form-label fw-bold small text-primary">⭐ 별점 평가 변경</label>
                <select class="form-select py-2 rounded-3" id="rating" style="border-color: rgba(255, 107, 53, 0.3);">
                    <option value="5">⭐⭐⭐⭐⭐ (최고의 선택)</option>
                    <option value="4">⭐⭐⭐⭐ (다시 가고 싶음)</option>
                    <option value="3">⭐⭐⭐ (무난하고 보통)</option>
                    <option value="2">⭐⭐ (조금 아쉬움)</option>
                    <option value="1">⭐ (추천하지 않음)</option>
                </select>
            </div>

            {{#review.imageUrls.0}}
                <div class="mb-4">
                    <label class="form-label fw-bold small text-muted d-block mb-2">📸 아카이빙된 사진첩</label>
                    <div id="carouselExampleControls" class="carousel slide rounded-3 overflow-hidden border shadow-sm" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            {{#review.imageUrls}}
                                <div class="carousel-item {{^first}}active{{/first}}">
                                    <img src="{{.}}" class="d-block w-100" style="height: 340px; object-fit: cover;" alt="리뷰 상세 사진">
                                </div>
                            {{/review.imageUrls}}
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        </button>
                    </div>
                </div>
            {{/review.imageUrls.0}}

            <div class="mb-5">
                <label for="review-content" class="form-label fw-bold small text-primary">식당 후기 문맥 수정</label>
                <textarea class="form-control p-3 rounded-3" id="review-content" rows="5" style="line-height: 1.6;">{{review.content}}</textarea>
            </div>

            <div class="d-flex justify-content-between gap-2 pt-2">
                <a href="/reviews" class="btn btn-light border py-2 fw-semibold" style="width: 25%;">돌아가기</a>
                <button type="button" class="btn btn-outline-danger py-2 fw-semibold" id="btn-delete-review" style="width: 25%;">기록 삭제</button>
                <button type="button" class="btn py-2 fw-bold text-white flex-grow-1" id="btn-update-review" style="background-color: var(--feed-primary);">수정 명세 반영하기</button>
            </div>
        </form>
    </div>
</div>

{{>layout/footer}}